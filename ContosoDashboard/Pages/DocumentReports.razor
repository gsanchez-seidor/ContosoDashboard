@page "/document-reports"
@using ContosoDashboard.Services.Documents
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "Administrator")]
@inject IDocumentReportingService DocumentReportingService

<PageTitle>Document Reports - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1>Document Activity Reports</h1>
            <p class="text-muted mb-0">Aggregate activity counts by action type.</p>
        </div>
    </div>

    @if (reportItems == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!reportItems.Any())
    {
        <div class="alert alert-info">No document activity found for selected range.</div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Activity Type</th>
                            <th>Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in reportItems)
                        {
                            <tr>
                                <td>@item.ActivityType</td>
                                <td>@item.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<DocumentActivityReportItem>? reportItems;

    protected override async Task OnInitializedAsync()
    {
        reportItems = await DocumentReportingService.GetActivitySummaryAsync();
    }
}
