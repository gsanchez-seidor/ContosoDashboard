@page "/tasks/{taskId:int}"
@using ContosoDashboard.Models
@using ContosoDashboard.Services.Documents
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ITaskService TaskService
@inject IDocumentService DocumentService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Task Details - ContosoDashboard</PageTitle>

<div class="container-fluid">
    @if (task == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="row mb-4">
            <div class="col">
                <h1>@task.Title</h1>
                <p class="text-muted mb-0">@task.Description</p>
            </div>
            <div class="col-auto">
                <a class="btn btn-primary" href="/documents?taskId=@task.TaskId&projectId=@task.ProjectId">Upload Document for Task</a>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Linked Documents</div>
            <div class="card-body">
                @if (!taskDocuments.Any())
                {
                    <p class="text-muted mb-0">No linked documents yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var doc in taskDocuments)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <span>@doc.Title (@doc.Category)</span>
                                <span class="text-muted">@FormatSize(doc.FileSizeBytes)</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int TaskId { get; set; }

    private TaskItem? task;
    private List<TaskDocumentLinkDto> taskDocuments = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(claim, out var userId) || userId <= 0)
        {
            return;
        }

        task = await TaskService.GetTaskByIdAsync(TaskId, userId);
        if (task != null)
        {
            taskDocuments = await DocumentService.GetTaskDocumentsAsync(userId, TaskId);
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var kb = bytes / 1024d;
        if (kb < 1024)
        {
            return $"{kb:F1} KB";
        }

        return $"{kb / 1024d:F1} MB";
    }
}
